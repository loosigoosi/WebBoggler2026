<UserControl
    x:Class="WebBoggler.SoundFX"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WebBoggler">
    
    <Grid>
        <MediaElement x:Name="wavButtonTick" Source="ms-appx:/SoundFX/button-tick.mp3" AutoPlay="False"/>
        <MediaElement x:Name="wavErase" Source="ms-appx:/SoundFX/laser.mp3" AutoPlay="False"/>
        <MediaElement x:Name="wavStartChime" Source="ms-appx:/SoundFX/1-tone-chime.mp3" AutoPlay="False"/>
        <MediaElement x:Name="wavEndChime" Source="ms-appx:/SoundFX/2-tone-chime.mp3" AutoPlay="False"/>
        <MediaElement x:Name="wavFail" Source="ms-appx:/SoundFX/fail-short.mp3" AutoPlay="False"/>
        <MediaElement x:Name="wavShake" Source="ms-appx:/SoundFX/shaking-pillbottle.mp3" AutoPlay="False"/>
        <MediaElement x:Name="wavAddWord" Source="ms-appx:/SoundFX/add-word.mp3" AutoPlay="False"/>
    </Grid>
    
</UserControl>
