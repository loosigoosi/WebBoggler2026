<UserControl
    x:Class="WebBoggler.SoundFX"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WebBoggler">
    
    <Grid>
        <MediaElement x:Name="wavButtonTick" Source="/SoundFX/button-tick.mp3" AutoPlay="False"/>
        <MediaElement x:Name="wavErase" Source="/SoundFX/laser.mp3" AutoPlay="False"/>
        <MediaElement x:Name="wavStartChime" Source="/SoundFX/1-tone-chime.mp3" AutoPlay="False"/>
        <MediaElement x:Name="wavEndChime" Source="/SoundFX/2-tone-chime.mp3" AutoPlay="False"/>
        <MediaElement x:Name="wavFail" Source="/SoundFX/fail-short.mp3" AutoPlay="False"/>
        <MediaElement x:Name="wavShake" Source="/SoundFX/shaking-pillbottle.mp3" AutoPlay="False"/>
        <MediaElement x:Name="wavAddWord" Source="/SoundFX/add-word.mp3" AutoPlay="False"/>
    </Grid>
    
</UserControl>
