<Page x:Class="WebBoggler.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:WebBoggler"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      Foreground="{DynamicResource Theme_TextBrush}">

    <Grid Background="{DynamicResource Theme_BackgroundBrush}">
        <!--Background="#FF202020">-->

        <Canvas HorizontalAlignment="Stretch" UseLayoutRounding="True">
            <local:SoundFX x:Name="sfxSoundPlayer">

                
            </local:SoundFX>
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border HorizontalAlignment="Center" Height="50" Width="505" CornerRadius="5" Margin="10,10,0,10" BorderThickness="2" BorderBrush="#FF303030">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock HorizontalAlignment="Left" Width="190" Height="55" Text="WebBoggler" Margin="0" Foreground="#FFD06000" FontSize="30" FontWeight="Bold" TextAlignment ="Center" /> <!--Background="#00EEEEEE"--> 
                            <TextBlock HorizontalAlignment="Left" Padding="0,1,0,0" Width="300" Height="45" Text="-  Maxi Paroliere online" Margin="0,0,0,0" Foreground="#FFD06000" FontSize="24" FontWeight="Bold" TextAlignment ="Left"/> <!--Background="#00EEEEEE"--> 
                        </StackPanel>
                    </Border>
                    <Border HorizontalAlignment="Center" Height="50" Width="300" CornerRadius="5" Padding="0,10,10,0" Margin="10,10,0,10" BorderThickness="2" BorderBrush="#FF303030">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <StackPanel x:Name="spLogin" Orientation="Horizontal" VerticalAlignment ="Center" HorizontalAlignment="Right" Visibility="Visible">
                                <TextBox Foreground="#FFE0E0E0" Text="Nickname: " Margin="0,0,5,0" FontSize="12" BorderThickness="0" TextAlignment="Right" Background="#00E0E0E0" Width="80" Height="25" VerticalContentAlignment="Center"/>
                                <TextBox x:Name="txtUserName" Foreground="#FF101010" Background="#FFE0E0E0" Width="100" Height="25"/>
                            </StackPanel>
                            <Button x:Name="cmdJoin" IsEnabled="False" Width="90" Height="25" Margin="10,0,10,0" FontSize="14" Content="Partecipa" HorizontalContentAlignment="Center" Tag="Join" /><!--Background="#FF808080"-->
                        </StackPanel>
                    </Border>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="10,10,0,0" HorizontalAlignment="Stretch" >
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Width="150" HorizontalAlignment="Stretch" >
                            <TextBox Text="Giocatori" Width="110" FontSize="14" Height="20" TextAlignment="Left" Foreground="#FFA0A0A0" Background="#00000000" BorderBrush="#00000000"/>
                            <TextBox Text="Punti" FontSize="14" Height="20" TextAlignment="Right" Foreground="#FFA0A0A0" Background="#00000000" BorderBrush="#00000000"/>
                        </StackPanel>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"  Height="480" VerticalScrollBarVisibility="Auto" Margin="0,0,5,0" BorderThickness="2" BorderBrush="#FF303030" >
                            <ListBox x:Name="lbPlayersList" HorizontalAlignment="Center" SelectionMode="Single" Width="150" Height="475" Background="#00000000">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderThickness="1" Height="25" BorderBrush="#FF303030" VerticalAlignment="Center" Margin="1,1,1,0">
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Background="#00000000">
                                                <TextBlock Text="{Binding NickName}" Cursor="Hand" Margin=" 1,1,0,0" Foreground="#FFA0A0F0" Width="115" Height="30" FontSize="14" TextAlignment ="Left" /><!--Background="#00000000"-->
                                                <TextBlock Text="{Binding Score}" Cursor="Hand" Margin=" 1,1,2,0" Foreground="#FFA0A0F0" Width="20" Height="30" FontSize="14" FontWeight="Bold" TextAlignment ="Right" /><!--Background="#0000000"-->
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </StackPanel>
                    <StackPanel x:Name="panPlayersWordList" Visibility="Collapsed" Margin="10,0,30,0">
                        <TabControl  Background="#00000000" BorderBrush="#FF303030" Height="485" Width="170" SelectedItem="0">
                            <TabItem Header="Risultati" BorderBrush="#FF303030" BorderThickness="2"><!-- Foreground="#FFA0A0A0"  SelectedBackground="#FF303030" SelectedForeground="#FFEAAA00" Background="#00000000"-->
                                <Grid>
                                    <TextBox Text="Parole" FontSize="14" Width="150"  Height="20"  TextAlignment="Center" Foreground="#FFA0A0A0" Background="#00000000" BorderBrush="#00000000"/>
                                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" Height="480" VerticalScrollBarVisibility="Auto">
                                        <ListBox x:Name="lbPlayersWordList" HorizontalAlignment="Center" SelectionMode="Single" Height="475" Width="180" Margin="1,0,0,0" BorderThickness="2"  BorderBrush="#FF303030">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding WordText}" Cursor="Hand" Margin=" 1,1,1,1" Foreground="#FFC01000" Width="150" Height="22" FontSize="16" FontWeight="Bold" TextAlignment ="Center" /><!--Background="#FFE0E0E0"-->
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </ScrollViewer>
                                </Grid>
                            </TabItem>
                            <TabItem Header="Soluzione" BorderBrush="#FF303030" BorderThickness="2"  Foreground="#FFA0A0A0" Background="#00000000"><!--SelectedBackground="#FF303030" SelectedForeground="#FFEAAA00"-->
                                <Grid>
                                    <TextBox Text="Parole di 7+ lettere " FontSize="14" Width="150"  Height="20"  TextAlignment="Center" Foreground="#FFA0A0A0" Background="#00000000" BorderBrush="#00000000"/>
                                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" Height="480" VerticalScrollBarVisibility="Auto">
                                        <ListBox x:Name="lbSolution" HorizontalAlignment="Center" SelectionMode="Single" Height="475" Width="180" Margin="1,0,0,0" BorderThickness="2"  BorderBrush="#FF303030">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding WordText}" Cursor="Hand" Margin=" 1,1,1,1" Foreground="#FFC01000" Width="170" Height="22" FontSize="16" FontWeight="Bold" TextAlignment ="Center" /><!--Background="#FFE0E0E0"-->
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </ScrollViewer>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </StackPanel>
                    <Grid  Margin="10,35,10,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="35"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <CheckBox x:Name="chkSounds" Content="Suoni" IsChecked="True" Grid.Row="0" HorizontalAlignment="Left" Margin="0" Foreground="#FFE0E0E0" FontSize="14" VerticalContentAlignment="Center"/>
                        <local:HourglassControl x:Name="hcHourglass" Grid.Row="1" BorderBrush="#FF303030" Visibility="Visible"/>
                    </Grid>
                    <StackPanel HorizontalAlignment="Center"  VerticalAlignment="Stretch" Width="400">
                        <StackPanel Orientation="Vertical">
                            <!--<Border HorizontalAlignment="Center" Height="30" Width="400" Margin="0,20,0,10" BorderThickness="2" BorderBrush="#FF303030">-->
                            <TextBlock x:Name="txtGameStatus" HorizontalAlignment="Center" Width="230" Height="20" Text="" Margin="0,15,0,5" Foreground="#FFEAAA00" FontSize=" 14" FontWeight="Bold" TextAlignment ="Center"  /><!--Background="#00EEEEEE"-->
                            <!--</Border>-->
                            <Border HorizontalAlignment="Center" Height="40" Width="400" CornerRadius="5" Margin="0,0,0,5" BorderThickness="2" BorderBrush="#FF303030" UseLayoutRounding="true">
                                <StackPanel HorizontalAlignment="Center">
                                    <StackPanel  x:Name="panGameControls"  Visibility="Collapsed"  Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock x:Name="txtInputWord" Width="230" Height="30" Margin="0,5,0,0" Text="" Foreground="#FFC01000" FontSize=" 24" FontWeight="Bold" TextAlignment ="Center"  /><!--Background="#FFEEEEEE"-->
                                        <Button x:Name="cmdClearWord" Width="40" Height="30" Margin="0,5,0,0" Content="X" FontSize="20" Padding="0,-5" Background="#FFA08080" Foreground="#FFB01010" FontWeight="Bold" HorizontalAlignment="Right"/>
                                        <Button x:Name="cmdAddWord" IsEnabled="False" Width="100" Margin="0,5,0,0" Height="30" Content="Aggiungi >" Tag="Aggiungi >" FontSize=" 14" FontWeight="Bold" HorizontalAlignment="Right" Background="#FF808080" Foreground="#FF007500"/>
                                    </StackPanel>
                                    <StackPanel x:Name="panGameStatus" Visibility="Visible" Orientation="Vertical" HorizontalAlignment="Center">
                                        <TextBlock x:Name="txtGameSubStatus" HorizontalAlignment="Center" Width="230" Height="18" Margin="0,5,0,0" Text="" Padding="0,5,0,0" Foreground="#FFEAAA00" FontSize=" 12" TextAlignment ="Center"  /><!--Background="#00EEEEEE"-->
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <Grid>
                            <Border Padding="0,8,0,8" CornerRadius="5" Margin="0,0,0,0" BorderThickness="2" BorderBrush="#FF303030">
                                <local:BoardGrid x:Name="bgBoard" Width="380" Height="380" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin ="0,0,0,5">
                            <TextBlock x:Name="txtWordCount" Width="120" Height="20" Grid.Column="0"  Margin ="0,10,0,0" Text="Parole possibili: " Foreground="#FFEAAA00" FontSize=" 12" TextAlignment ="Center"/>
                            <TextBlock x:Name="txtFoundWordCount" Visibility="Collapsed" Width="120" Height="20" Grid.Column="0" Margin ="20,10,0,0" Text="" Foreground="#FFEAAA00" FontSize=" 12" TextAlignment ="Center"/>
                        </StackPanel>
                        <!--<Border BorderThickness="2" Padding="5" CornerRadius="5" BorderBrush="#FF303030" Margin="0,5,0,0" >
                    </Border>-->
                    </StackPanel>
                    <StackPanel x:Name="panLocalWordList">
                        <TextBox Text="Parole" FontSize="14" Width="150" Height="20"  TextAlignment="Center" Foreground="#FFA0A0A0" Background="#00000000" BorderBrush="#00000000"/>
                        <ScrollViewer HorizontalScrollBarVisibility="Disabled" Height="480" VerticalScrollBarVisibility="Auto" Margin="10,0,0,0" BorderThickness="2"  BorderBrush="#FF303030">
                            <ListBox x:Name="lbWordList" HorizontalAlignment="Center" SelectionMode="Single" Width="150" Height="475">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding WordText}" Cursor="Hand" Margin=" 1,1,1,1" Foreground="#FFC01000" Width="147" Height="22" FontSize="16" FontWeight="Bold" TextAlignment ="Center"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </ScrollViewer>
                    </StackPanel>
                </StackPanel>
                <Border HorizontalAlignment="Center" Height="35" Width="815" CornerRadius="5" Margin="10,15,0,10" BorderThickness="1" BorderBrush="#FF303030">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock HorizontalAlignment="Center" Padding="0,10,0,0" Width="460" Height="30" Text="WebBoggler  -  ©2016 Xidea/FlavioRonco" Margin="0,0,0,0" Foreground="#FF909090" FontSize="12" TextAlignment ="Right"/>
                        <HyperlinkButton  HorizontalAlignment="Left" Padding="0,10,0,0" Width="200" Height="30" NavigateUri="http://www.chiaveastella.it" Content="www.chiaveastella.it"  Margin="10,0,20,0" Foreground="#FF909090" FontSize="12" Background="#00EEEEEE" Cursor="Hand" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Canvas>
    </Grid>
</Page>
